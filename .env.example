# Copy this file to .env and fill in the values you need.
# .env is git-ignored and never committed.

# ---------------------------------------------------------------------------
# Relay orchestrator (LLM-based done/loop/escalate evaluation)
# ---------------------------------------------------------------------------

# Set to 1 to enable the relay orchestrator
AI_WHISPER_RELAY_ORCHESTRATOR_ENABLED=0

# Maximum rounds before the orchestrator forces escalation (default: 3)
# AI_WHISPER_RELAY_ORCHESTRATOR_MAX_ROUNDS=3

# Evaluator provider: "anthropic" (default) or "ollama"
AI_WHISPER_EVALUATOR_PROVIDER=anthropic

# Optional fallback provider if primary is unavailable ("anthropic" or "ollama")
# AI_WHISPER_EVALUATOR_FALLBACK=

# --- Anthropic (used when provider=anthropic or as fallback) ---
# Required when AI_WHISPER_EVALUATOR_PROVIDER=anthropic (or fallback=anthropic)
ANTHROPIC_API_KEY=

# --- Ollama (used when provider=ollama or as fallback) ---
# Ollama server address (default: http://localhost:11434)
# AI_WHISPER_EVALUATOR_OLLAMA_HOST=http://localhost:11434
# Model to use — qwen2.5:7b-instruct recommended for judge tasks
# AI_WHISPER_EVALUATOR_OLLAMA_MODEL=qwen2.5:7b-instruct

# ---------------------------------------------------------------------------
# Provider executables (override if not on PATH)
# ---------------------------------------------------------------------------

# AI_WHISPER_CODEX_CMD=codex
# AI_WHISPER_CLAUDE_CMD=claude

# ---------------------------------------------------------------------------
# Tuning
# ---------------------------------------------------------------------------

# Milliseconds of PTY idle time before auto-handback triggers (default: 30000)
# AI_WHISPER_IDLE_THRESHOLD_MS=30000

# Write raw PTY input to a file for debugging (optional)
# AI_WHISPER_DEBUG_INPUT_LOG=/tmp/whisper-input.log
