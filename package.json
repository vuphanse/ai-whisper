{
	"name": "ai-whisper",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r --if-present build",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit -p tsconfig.json && pnpm -r --if-present typecheck",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --check \"{package.json,pnpm-workspace.yaml,tsconfig*.json,vitest.config.ts,eslint.config.mjs,prettier.config.mjs}\" \"packages/*/{package.json,tsconfig.json}\" \"packages/*/src/**/*.ts\" \"test/**/*.ts\"",
		"format:write": "prettier --write \"{package.json,pnpm-workspace.yaml,tsconfig*.json,vitest.config.ts,eslint.config.mjs,prettier.config.mjs}\" \"packages/*/{package.json,tsconfig.json}\" \"packages/*/src/**/*.ts\" \"test/**/*.ts\""
	},
	"devDependencies": {
		"@eslint/js": "^9.23.0",
		"@stylistic/eslint-plugin": "^2.13.0",
		"@types/node": "^22.13.10",
		"@types/react": "^19.2.14",
		"eslint": "^9.23.0",
		"globals": "^16.0.0",
		"ink": "^7.0.3",
		"ink-testing-library": "^4.0.0",
		"prettier": "^3.5.3",
		"react": "^19.2.6",
		"tsx": "^4.19.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.27.0",
		"vitest": "^3.1.1",
		"zod": "^3.25.76"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"better-sqlite3",
			"esbuild",
			"node-pty"
		]
	}
}
